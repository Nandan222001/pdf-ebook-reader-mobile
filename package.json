{
  "name": "pdf-ebook-reader-mobile",
  "version": "1.0.0",
  "description": "A beautiful PDF e-book reader mobile app with book-like UI/UX, annotations, and SQLite persistence",
  "author": "Nandan222001",
  "license": "MIT",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build -p android --profile preview",
    "build:ios": "eas build -p ios --profile preview",
    "build:production": "eas build --profile production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~51.0.28",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-linear-gradient": "~13.0.2",
    "expo-router": "~3.5.23",
    "expo-sqlite": "~13.4.0",
    "expo-status-bar": "~2.0.0",
    "lucide-react-native": "^0.408.0",
    "nativewind": "^2.0.11",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-document-picker": "^9.1.2",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-pdf": "^1.13.2",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-view-shot": "3.8.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "tailwindcss": "^3.4.10",
    "typescript": "~5.3.3"
  },
  "private": true
}
